{
    "info": {
        "_postman_id": "1e228499-9f1a-4e95-b8ec-188b4a6076ef",
        "name": "TPB Ormawa API v1",
        "description": "Collection untuk testing API mobile ormawa TPB.\n\nGunakan endpoint login terlebih dahulu. Token akan otomatis disimpan ke variable collection `token`.\n\nCatatan session: jika login di web atau mobile perangkat lain, request protected bisa membalas 401 SESSION_EXPIRED.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost/api/v1",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "barang_id",
            "value": "1",
            "type": "string"
        },
        {
            "key": "keranjang_id",
            "value": "1",
            "type": "string"
        },
        {
            "key": "permohonan_id",
            "value": "1",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login Ormawa",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Esa\",\n  \"nim\": \"1234567\",\n  \"password\": \"@Poli1234567\",\n  \"device_name\": \"postman\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login",
                            "host": ["{{base_url}}"],
                            "path": ["auth", "login"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let jsonData = {};",
                                    "try { jsonData = pm.response.json(); } catch (e) {}",
                                    "if (pm.response.code === 200 && jsonData?.data?.access_token) {",
                                    "  pm.collectionVariables.set('token', jsonData.data.access_token);",
                                    "}",
                                    "pm.test('Login response valid', function () {",
                                    "  pm.expect(pm.response.code).to.be.oneOf([200, 401, 422]);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/auth/me",
                            "host": ["{{base_url}}"],
                            "path": ["auth", "me"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let jsonData = {};",
                                    "try { jsonData = pm.response.json(); } catch (e) {}",
                                    "if (pm.response.code === 401 && jsonData.code === 'SESSION_EXPIRED') {",
                                    "  console.log('Session expired, please login again.');",
                                    "}",
                                    "pm.test('Me request is authorized or session expired', function () {",
                                    "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/auth/logout",
                            "host": ["{{base_url}}"],
                            "path": ["auth", "logout"]
                        }
                    }
                }
            ]
